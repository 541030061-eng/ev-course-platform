.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 50%);
  padding: 80rpx 40rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1aad19;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
}

.tab-switch {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #888;
  transition: all 0.3s;
}

.tab.active {
  background: #1aad19;
  color: #fff;
  font-weight: bold;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.role-select {
  margin-bottom: 24rpx;
}

.role-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.role-options {
  display: flex;
  gap: 20rpx;
}

.role-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.role-btn.active {
  border-color: #1aad19;
  background: #e8f5e9;
  color: #1aad19;
  font-weight: bold;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #1aad19, #0d8c0d);
  color: #fff;
  border-radius: 12rpx;
  padding: 22rpx 0;
  font-size: 30rpx;
  margin-top: 20rpx;
  border: none;
}

.tips {
  text-align: center;
  color: #aaa;
  font-size: 24rpx;
  margin-top: 40rpx;
}
