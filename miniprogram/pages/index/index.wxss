.filter-bar {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
  margin-bottom: 10rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.filter-item.active {
  background: #1aad19;
  color: #fff;
}

.post-item {
  transition: all 0.2s;
}

.post-item:active {
  background: #f9f9f9;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.post-user {
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.post-time {
  font-size: 22rpx;
  color: #aaa;
}

.post-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 12rpx;
}

.post-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.post-file {
  font-size: 24rpx;
  color: #1aad19;
  background: #e8f5e9;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.visibility-tag {
  font-size: 22rpx;
  color: #bbb;
}

.post-action {
  font-size: 28rpx;
  padding: 8rpx;
}
