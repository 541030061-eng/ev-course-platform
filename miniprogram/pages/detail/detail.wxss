.detail-header {
  margin-bottom: 20rpx;
}

.post-user {
  display: flex;
  align-items: center;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.post-time {
  font-size: 22rpx;
  color: #aaa;
}

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.detail-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.detail-file {
  font-size: 26rpx;
  color: #1aad19;
  background: #e8f5e9;
  padding: 14rpx 20rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
}

.detail-visibility {
  font-size: 22rpx;
  color: #bbb;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 评论区 */
.comment-section {
  margin-top: 20rpx;
}

.comment-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.comment-item {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 6rpx;
}

.comment-time {
  font-size: 20rpx;
  color: #bbb;
}

/* 评论输入 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.03);
}

.comment-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.send-btn {
  background: #1aad19;
  color: #fff;
  border-radius: 30rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  border: none;
}
