.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.input {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.textarea {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  min-height: 180rpx;
  width: 100%;
  box-sizing: border-box;
}

.option-row {
  display: flex;
  gap: 16rpx;
}

.option {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.option.active {
  border-color: #1aad19;
  background: #e8f5e9;
  color: #1aad19;
  font-weight: bold;
}

.picker {
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.user-select-list {
  max-height: 300rpx;
  overflow-y: auto;
}

.user-checkbox {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
}

.file-info {
  background: #e8f5e9;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #1aad19;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.remove-file {
  color: #f44336;
  font-size: 28rpx;
  padding: 0 10rpx;
}

.upload-btn {
  width: 100%;
}

.submit-btn {
  width: 100%;
  margin-top: 30rpx;
}
