.profile-card {
  background: linear-gradient(135deg, #1aad19, #0d8c0d);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
  color: #fff;
}

.profile-avatar {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.profile-role {
  margin-bottom: 8rpx;
}

.tag-teacher { background: rgba(255,255,255,0.3); color: #fff; }
.tag-student { background: rgba(255,255,255,0.3); color: #fff; }

.profile-id {
  font-size: 24rpx;
  opacity: 0.7;
}

.stats-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1aad19;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.my-post-item {
  transition: all 0.2s;
}

.my-post-item:active {
  background: #f9f9f9;
}

.my-post-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.my-post-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.my-post-time {
  font-size: 22rpx;
  color: #bbb;
}

.logout-btn {
  width: 100%;
  background: #fff;
  color: #f44336;
  border: 2rpx solid #f44336;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-top: 30rpx;
}
